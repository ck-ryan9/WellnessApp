<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ProgressActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Progress"
            android:textSize="32sp"
            android:textAlignment="center"
            android:textStyle="bold"
            android:background="@drawable/shape"
            android:padding="10dp"
            android:textColor="#F204EE"/>

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:src="@drawable/progress"
            android:scaleType="centerCrop"/>

        <TextView
            android:id="@+id/recipesText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Check Your Progress\n\nTake a moment to reflect on how far you’ve come 📊\n\nProgress is not always perfect, but every effort you’ve made counts.\nThink about the goals you set and the steps you’ve taken so far.\n\nCelebrate what you’ve achieved, even the small wins—they matter more than you think.\n\nIf things didn’t go as planned, don’t be discouraged.\nLearn from it, adjust your approach, and keep moving forward.\n\nConsistency is the key to success. Keep showing up and doing your best each day.\n\nRemember, growth takes time. Stay patient, stay focused, and trust the process 💪"
            android:textSize="16sp"
            android:background="#978"
            android:padding="16dp"/>

        <Button
            android:id="@+id/btnCheckProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📊 Check My Progress"
            android:textSize="18sp"
            android:padding="14dp"
            android:backgroundTint="#3F51B5"
            android:textColor="@android:color/white"
            android:layout_marginTop="12dp"/>

    </LinearLayout>

</ScrollView>