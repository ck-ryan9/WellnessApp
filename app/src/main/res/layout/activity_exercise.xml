<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#331311"
    tools:context=".ExerciseActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Exercises"
            android:textSize="32sp"
            android:textAlignment="center"
            android:textStyle="bold"
            android:background="@drawable/shape"
            android:padding="10dp"
            android:textColor="#04F2DA"/>

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:src="@drawable/exercise1"
            android:scaleType="centerCrop"/>

        <TextView
            android:id="@+id/recipesText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fitness And Exercise\n\nTake a moment to move your body and boost your energy 💪\n\nRegular exercise improves your strength, mood, and overall health.\nYou don’t need a gym—simple activities like stretching, walking, or light workouts can make a big difference.\n\nStay consistent, stay strong, and keep pushing yourself.\nEvery small step counts towards a healthier you."
            android:textSize="16sp"
            android:background="#792"
            android:padding="16dp"/>

        <Button
            android:id="@+id/btnStartExercise"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="▶️ Start Exercise"
            android:textSize="18sp"
            android:padding="14dp"
            android:backgroundTint="#F44336"
            android:textColor="@android:color/white"
            android:layout_marginTop="12dp"/>

        <Button
            android:id="@+id/btnQuickWorkout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚡ Quick 5-Min Workout"
            android:backgroundTint="#FF5722"
            android:textColor="@android:color/white"
            android:layout_marginTop="10dp"/>

        <Button
            android:id="@+id/btnTrackProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📈 Track Progress"
            android:backgroundTint="#3F51B5"
            android:textColor="@android:color/white"
            android:layout_marginTop="10dp"/>

    </LinearLayout>

</ScrollView>