<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    android:id="@+id/main"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="#17F0C5"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

<!--    Below is a linear layout that holds all our views-->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="20dp"
        android:orientation="vertical">



<!--        Below is a TextView -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Health and Wellness App"
            android:textSize="45sp"
            android:textAlignment="center"
            android:textStyle="bold"
            android:textColor="#9D5D3D"/>

<!--        Below is an image-->
        <ImageView
            android:layout_marginTop="15dp"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:src="@drawable/image1" />

        <com.google.android.gms.ads.AdView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/adView"
            app:adSize="BANNER"
            app:adUnitId="ca-app-pub-3940256099942544/6300978111"/>

<!--        Below is button number 1-->
        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/health_recipes"
            android:text="HEALTHY RECIPES"
            android:textSize="20sp"
            android:drawableLeft="@drawable/recipe"
            android:backgroundTint="#234"
            android:layout_marginTop="15dp"/>

<!--        Below is button number two-->
        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/nutrition_advice"
            android:text="NUTRITION ADVICE"
            android:textSize="20sp"
            android:drawableLeft="@drawable/wellness"
            android:backgroundTint="#534"
            android:layout_marginTop="15dp"/>

<!--        Below is button three-->
        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/meditation"
            android:text="MEDITATION"
            android:drawableLeft="@drawable/meditation"
            android:textSize="20sp"
            android:backgroundTint="#943"
            android:layout_marginTop="15dp"/>

<!--        Button four-->
        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/hydration_alert"
            android:text="HYDRATION ALERT"
            android:drawableLeft="@drawable/hydration"
            android:textSize="20sp"
            android:backgroundTint="#000C44"
            android:layout_marginTop="15dp"/>

<!--        Button five-->
        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/start_exercise"
            android:text="START EXERCISE"
            android:drawableLeft="@drawable/exercise"
            android:textSize="20sp"
            android:backgroundTint="#874"
            android:layout_marginTop="15dp"/>

<!--        Button six-->
        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/daily_motivation"
            android:text="DAILY MOTIVATION"
            android:drawableLeft="@drawable/motivation1"
            android:textSize="20sp"
            android:backgroundTint="#474"
            android:layout_marginTop="15dp"/>

        <!--        Button seven-->
        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/weekly_goals"
            android:text="WEEKLY GOALS"
            android:drawableLeft="@drawable/goal"
            android:textSize="20sp"
            android:backgroundTint="#234"
            android:layout_marginTop="15dp"/>

        <!--        Button eight-->
        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/check_progress"
            android:text="CHECK PROGRESS"
            android:drawableLeft="@drawable/performance"

            android:textSize="20sp"
            android:backgroundTint="#642374"
            android:layout_marginTop="15dp"/>

<!--            Button nine-->

            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/learnmore"
                android:text="LEARN MORE....."
                android:drawableLeft="@drawable/knowledge"
                android:textSize="20sp"
                android:backgroundTint="#421"
                android:layout_marginTop="15dp"/>








    </LinearLayout>


</ScrollView>