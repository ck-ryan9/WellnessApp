<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#112533"
    tools:context=".HydrationActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hydration"
            android:textSize="32sp"
            android:textAlignment="center"
            android:textStyle="bold"
            android:background="@drawable/shape"
            android:padding="10dp"
            android:textColor="#08D929"/>

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:src="@drawable/hydration1"
            android:scaleType="centerCrop"/>

        <TextView
            android:id="@+id/recipesText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hydration Reminder\n\nTake a moment to drink some water 💧\nYour body needs it to stay energized and focused.\n\nEven if you don’t feel thirsty, a few sips can make a big difference.\nStaying hydrated helps your skin, digestion, and overall health.\n\nPause, refresh, and keep going strong.\nA healthy habit starts with a single glass of water."
            android:textSize="16sp"
            android:background="#792"
            android:padding="16dp"/>

        <Button
            android:id="@+id/btnDrinkNow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💧 Drink Water Now"
            android:textSize="16sp"
            android:padding="12dp"
            android:backgroundTint="#4CAF50"
            android:textColor="@android:color/white"
            android:layout_marginTop="10dp"/>

        <Button
            android:id="@+id/btnRemindLater"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⏰ Remind Me Later"
            android:textSize="16sp"
            android:padding="12dp"
            android:backgroundTint="#FF9800"
            android:textColor="@android:color/white"
            android:layout_marginTop="10dp"/>

        <Button
            android:id="@+id/btnTrackWater"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📊 Track My Intake"
            android:textSize="16sp"
            android:padding="12dp"
            android:backgroundTint="#2196F3"
            android:textColor="@android:color/white"
            android:layout_marginTop="10dp"/>

    </LinearLayout>

</ScrollView>